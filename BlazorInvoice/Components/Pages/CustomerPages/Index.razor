@code {

    // For the list displayed in the table

    List<CustomCustomer> customers;


    // Store IDs of customers after sorting...............................
    List<int> SortedCustomersIds;

    protected override void OnInitialized()
    {
        GetCustomersWithPaymentStatus();
    }



    public void GetCustomersWithPaymentStatus()
    {
        var now = DateTime.Now;

        var customersWithInvoices = DB.Customer
            .Select(c => new CustomCustomer
                {
                    Id = c.Id,
                    Name = c.Name,
                    Address = c.Address,
                    Phone = c.Phone,
                    Status = Status.Active,

                    // 🔹 أقرب تاريخ دفع غير مدفوع
                    PaymentDate = DB.Payments
                            .Where(p => p.Invoice.CustomerId == c.Id && !p.Paid)
                            .OrderBy(p => p.Date)
                            .Select(p => p.Date)
                            .FirstOrDefault()
                })
            .ToList();

        // 🔹 الآن نحسب PaymentStatus فقط إذا كان لديه فاتورة
        foreach (var c in customersWithInvoices)
        {
            if (c.PaymentDate == default)
            {
                c.Status = Status.Inactive;
                c.PaymentStatus = PaymentStatus.Inactive;
            }
            else if (c.PaymentDate < now)
            {
                c.PaymentStatus = PaymentStatus.late;
            }
            else if (c.PaymentDate <= now.AddDays(10))
            {
                c.PaymentStatus = PaymentStatus.upComing;
            }
            else
            {
                c.PaymentStatus = PaymentStatus.Early;
            }
        }

        // 🔹 ترتيب العملاء: Inactive في الأسفل
        customers = customersWithInvoices
            .OrderBy(c => c.PaymentDate == default)
            .ThenBy(c => c.PaymentDate)
            .ToList();
    }
    public enum Status
    {
        Active,
        Inactive
    }
    public enum PaymentStatus
    {
        late, upComing, paid, Early, Inactive
    }



    //Class CustomCustomer makes complex database data something ready to be displayed and handled on the page in an organized and easy way.
    public class CustomCustomer
    {
        public int Id { get; set; }
        public string? Name { get; set; }
        public string? Address { get; set; }
        public string? Phone { get; set; }
        public Status? Status { get; set; }
        public DateTime PaymentDate { get; set; }
        public PaymentStatus? PaymentStatus { get; set; }
        public bool paid { get; set; }

    }




    private void SortByName()
    {
        customers = customers
            .OrderBy(c => c.Name)
            .ToList();
    }

    private void SortByPaymentDate()
    {
        customers = customers
            .Where(c => c.PaymentDate != default) // only customers with invoices
            .OrderBy(c => c.PaymentDate)
            .ToList();
    }



}