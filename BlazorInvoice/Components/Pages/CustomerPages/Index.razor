@* This page is linked to /customers *@
@page "/customers"

@* Is used to include the QuickGrid namespace in Blazor, allowing you to use its components directly in the page or component without writing the full namespace each time.
 *@
@using Microsoft.AspNetCore.Components.QuickGrid
@*  Call the database (InvoiceDbContext) within the page *@
@inject BlazorInvoice.Data.InvoiceDbContext DB
@* This specifies that the page is running in Blazor Server Mode *@
@rendermode InteractiveServer

@using BlazorInvoice.Models
@using System.Linq;
@using Microsoft.Data.SqlClient;
@using Microsoft.EntityFrameworkCore;
<style>


    /*     Table formatting: full width, lines to separate cells, even row highlighting, hover effect, and heading background.
     */
    .quickgrid-table {
        width: 100%;
        border-collapse: collapse;
    }

        .quickgrid-table th,
        .quickgrid-table td {
            border: 1px solid #ddd;
            padding: 8px;
        }

        .quickgrid-table th {
            background-color: #ca1010;
            text-align: left;
            font-weight: bold;
        }


        /* nth-child is a CSS selector that allows you to apply a style to an element based
        on its order among its siblings. nth-child(even) → Applies the style to rows that have an even order (2, 4, 6...). */
        .quickgrid-table tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .quickgrid-table tr:hover {
            background-color: #f1f1f1;
        }
</style>
<PageTitle>Index</PageTitle>
<button @onclick="GetCustomersWithPaymentStatus">All Customers</button>

