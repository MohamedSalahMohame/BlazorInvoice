    protected override async Task OnInitializedAsync()
    {
        Customers = await dbContext.Customer.ToListAsync();

        // تحميل الفاتورة
        invoice = await dbContext.Invoices
            .Include(x => x.InvoiceItems)
            .FirstOrDefaultAsync(x => x.Id == id);

        if (invoice == null)
        {
            NavigationManager.NavigateTo("/invoices/index");
            return;
        }

        CustomerId = invoice.CustomerId;
        selectedCurrency = invoice.Currency;

        // تعيين معدل التحويل عند الدينار
        DollarBoDinar = invoice.DollarBoDinar > 0 ? invoice.DollarBoDinar : 10; // 10 قيمة افتراضية

        // عرض اسم العميل مباشرة في مربع البحث
        var customer = Customers.FirstOrDefault(c => c.Id == CustomerId);
        if (customer != null)
        {
            CustomerSearchText = customer.Name;
        }

        // تحميل العناصر الخاصة بالفاتورة
        var items = await dbContext.InvoiceItems
            .Where(x => x.InvoiceId == id)
            .Include(x => x.Item)
            .ToListAsync();

        Items = items.Select(x => new Item
            {
                Id = x.ItemId,
                ItemName = x.Item.ItemName,
                PurchasePrice = x.CostPrice,
                SalePrice = x.SalePrice,
                Quantity = x.Quantity
            }).ToList();

        // تحميل الأقساط
        payments = await dbContext.Payments
            .Where(x => x.InvoiceId == id)
            .OrderBy(x => x.Date)
            .ToListAsync();

        NoOfMonths = payments.Count;

        isLoaded = true;
    }

  

    private void DeleteSelectedItem(int id)
    {
        Items.Remove(Items.First(x => x.Id == id));
    }

    private async Task SearchItems()
    {
        var newItems = await dbContext.Items
            .Where(x => x.ItemName.Contains(item.SearchText!))
            .ToListAsync();

        foreach (var i in newItems)
        {
            var existing = Items.FirstOrDefault(x => x.Id == i.Id);

            if (existing != null)
                existing.Quantity++;
            else
            {
                i.Quantity = 1;
                Items.Add(i);
            }
        }
    }







    private async Task UpdateInvoice()
    {
        if (invoice == null) return;

        invoice.CustomerId = CustomerId;
        invoice.Payment = SimpleTotal;
        invoice.Currency = selectedCurrency;
        invoice.DollarBoDinar = selectedCurrency == Currency.DINAR ? DollarBoDinar : 1;

        // حذف العناصر القديمة
        var oldItems = dbContext.InvoiceItems
            .Where(x => x.InvoiceId == invoice.Id);
        dbContext.InvoiceItems.RemoveRange(oldItems);

        // إضافة العناصر الجديدة
        var newItems = Items.Select(i => new InvoiceItem
            {
                InvoiceId = invoice.Id,
                ItemId = i.Id,
                Quantity = i.Quantity,
                SalePrice = i.SalePrice,
                CostPrice = i.PurchasePrice
            });
        await dbContext.InvoiceItems.AddRangeAsync(newItems);

        // حذف الأقساط القديمة
        var oldPayments = dbContext.Payments
            .Where(x => x.InvoiceId == invoice.Id);
        dbContext.Payments.RemoveRange(oldPayments);

        // إنشاء نسخة جديدة للأقساط من القائمة الحالية، بدون أي كائنات متعلقة مسبقًا بالـ DbContext
        var newPayments = payments.Select(p => new Payment
            {
                InvoiceId = invoice.Id,
                Amount = p.Amount,
                Paid = p.Paid,
                Currency = p.Currency,
                Date = p.Date
            });

        await dbContext.Payments.AddRangeAsync(newPayments);

        await dbContext.SaveChangesAsync();

        NavigationManager.NavigateTo("/invoices/index");
    }
