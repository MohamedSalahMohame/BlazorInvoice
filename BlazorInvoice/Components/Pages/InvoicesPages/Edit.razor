    private void UpdatePaymentLogic(Payment payment)
{
    int newAmount = payment.Amount;

    int oldAmount = lastValidAmount;

    int difference = newAmount - oldAmount;

    payment.IsEdited = true;

    var remaining = payments
        .Where(p => !p.IsEdited)
        .ToList();

    if (remaining.Count == 0)
        return;

    int share = difference / remaining.Count;

    foreach (var p in remaining)
    {
        p.Amount -= share;
    }

    lastValidAmount = newAmount;
}




    private void HandleCurrency(Currency currency)
    {
        selectedCurrency = currency;

        HandleSelction(NoOfMonths);
    }

    private void HandleSelction(int noOfMonths)
    {
        NoOfMonths = noOfMonths;
        payments.Clear();

        var totalAmount = SimpleTotal;

        var amountPerPayment =
            Math.Round(totalAmount / (double)NoOfMonths, 2);

        var date = DateTime.Now;

        for (int i = 0; i < NoOfMonths; i++)
        {
            payments.Add(new Payment
                {
                    Date = date.AddMonths(i),
                    Amount = (int)amountPerPayment,
                    Currency = selectedCurrency
                });
        }
    }




    bool IsLocked(Payment payment)
    {
        var remaining = payments.Where(p => !p.IsEdited).ToList();

        return remaining.Count == 1 && !payment.IsEdited;
    }
















    private void ShowCustomers()
    {
        if (string.IsNullOrWhiteSpace(CustomerSearchText))
        {
            FilteredCustomers = Customers
                .OrderBy(x => x.Name)
                .Take(5)
                .ToList();
        }
    }

    private void FilterCustomers()
    {
        if (string.IsNullOrWhiteSpace(CustomerSearchText))
        {
            FilteredCustomers = Customers
                .OrderBy(x => x.Name)
                .Take(5)
                .ToList();
        }
        else
        {
            FilteredCustomers = Customers
                .Where(x => x.Name.Contains(CustomerSearchText,
                       StringComparison.OrdinalIgnoreCase))
                .OrderBy(x => x.Name)
                .Take(7)
                .ToList();
        }
    }

    private void SelectCustomer(Customer customer)
    {
        CustomerId = customer.Id;
        CustomerSearchText = customer.Name;

        FilteredCustomers.Clear();
    }











    private void ShowItems()
    {
        FilteredItems = dbContext.Items
            .OrderBy(x => x.ItemName)
            .Take(5)
            .ToList();
    }

    private void FilterItems()
    {
        if (string.IsNullOrWhiteSpace(item.SearchText))
        {
            FilteredItems = dbContext.Items
                .OrderBy(x => x.ItemName)
                .Take(5)
                .ToList();
        }
        else
        {
            FilteredItems = dbContext.Items
                .Where(x => x.ItemName.Contains(item.SearchText))
                .OrderBy(x => x.ItemName)
                .Take(7)
                .ToList();
        }
    }

    private void SelectItem(Item selectedItem)
    {
        var existing = Items.FirstOrDefault(x => x.Id == selectedItem.Id);

        if (existing != null)
            existing.Quantity++;
        else
        {
            selectedItem.Quantity = 1;
            Items.Add(selectedItem);
        }

        item.SearchText = "";
        FilteredItems.Clear();
    }



    private async Task ValidateAndUpdate(Payment payment)
    {
        if (payment.Amount < 0)
        {
            await JS.InvokeVoidAsync("alert", "النظام لا يقبل رقم سالب");
            payment.Amount = lastValidAmount;
            StateHasChanged();
            return;
        }

        // حل مشكلة 100-
        if (payment.Amount == 0 && lastValidAmount > 0)
        {
            payment.Amount = lastValidAmount;
            StateHasChanged();
            return;
        }

        if (payment.Amount > SimpleTotal)
        {
            await JS.InvokeVoidAsync("alert", "القيمة أكبر من الفاتورة");
            payment.Amount = lastValidAmount;
            StateHasChanged();
            return;
        }

        UpdatePaymentLogic(payment);
    }





    private void HideItems()
    {
        // نؤجل مسح القائمة قليلاً لإعطاء فرصة للنقر على العنصر
        Task.Delay(150).ContinueWith(_ =>
        {
            InvokeAsync(() =>
            {
                FilteredItems.Clear();
                StateHasChanged();
            });
        });
    }
    private void HideCustomers()
    {
        // نؤجل مسح القائمة قليلاً لإعطاء فرصة للنقر على عنصر من القائمة قبل الإخفاء
        Task.Delay(150).ContinueWith(_ =>
        {
            InvokeAsync(() =>
            {
                FilteredCustomers.Clear();
                StateHasChanged();
            });
        });
    }
}